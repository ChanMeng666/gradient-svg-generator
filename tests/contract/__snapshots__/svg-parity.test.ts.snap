exports[`SVG contract parity > fluids:aurora-streams 1`] = `
"<?xml version="1.0" encoding="UTF-8"?>
    <svg xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink" 
      width="854" height="120" viewBox="0 0 854 120">
      
    <defs>
      <linearGradient id="turbulentFlow" x1="0%" y1="0%" x2="100%" y2="100%">
        <stop offset="0%" style="stop-color:#00ff80;stop-opacity:0.9">
          <animate attributeName="stop-color" values="#00ff80;#80ff00;#00ff80" dur="9s" repeatCount="indefinite"/>
        </stop>
        <stop offset="50%" style="stop-color:#80ff00;stop-opacity:0.7">
          <animate attributeName="stop-color" values="#80ff00;#00ff40;#80ff00" dur="9s" repeatCount="indefinite"/>
        </stop>
        <stop offset="100%" style="stop-color:#00ff40;stop-opacity:0.5">
          <animate attributeName="stop-color" values="#00ff40;#40ff80;#00ff40" dur="9s" repeatCount="indefinite"/>
        </stop>
        <animateTransform attributeName="gradientTransform" type="translate" values="0 0;50 0;0 0" dur="9s" repeatCount="indefinite"/>
      </linearGradient>
      <filter id="fluidDistortion">
        <feTurbulence baseFrequency="0.8" numOctaves="4" result="noise"/>
        <feDisplacementMap in="SourceGraphic" in2="noise" scale="25">
          <animate attributeName="scale" values="15;35;15" dur="9s" repeatCount="indefinite"/>
        </feDisplacementMap>
      </filter>
    </defs>
    <rect width="100%" height="100%" fill="url(#turbulentFlow)" filter="url(#fluidDistortion)"/>
    <foreignObject x="10%" y="40%" width="80%" height="20%">
      <div xmlns="http://www.w3.org/1999/xhtml" style="
        color: #000000;
        font-family: 'Trebuchet MS', sans-serif;
        font-size: 28px;
        font-weight: bold;
        text-align: center;
        text-shadow: 0 0 20px #ffffff, 0 0 30px #ffffff, 0 0 40px #00ff80, 2px 2px 6px rgba(255,255,255,0.9);
        animation: fluidMotion 9s infinite;
      ">
        Hello World
      </div>
      <style>
        @keyframes fluidMotion {
          0%, 100% { transform: translateX(0px) skewX(0deg); }
          50% { transform: translateX(5px) skewX(2deg); }
        }
      </style>
    </foreignObject>
  
    </svg>"
`;

