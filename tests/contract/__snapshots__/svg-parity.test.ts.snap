      <stop offset="0%" stop-color="#000000" /><stop offset="100%" stop-color="#000000" />
      <animate attributeName="x1" values="-50%;50%;100%;50%;-50%" dur="6s" repeatCount="indefinite" />
      <animate attributeName="x2" values="50%;150%;200%;150%;50%" dur="6s" repeatCount="indefinite" />
    </linearGradient>
    
    <!-- Soft Light Filter -->
