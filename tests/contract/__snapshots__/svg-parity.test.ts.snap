        <stop offset="0%" stop-color="#f3e2c7" /><stop offset="20%" stop-color="#b68d4c" /><stop offset="40%" stop-color="#e9d4b3" /><stop offset="60%" stop-color="#f3e2c7" /><stop offset="80%" stop-color="#b68d4c" /><stop offset="100%" stop-color="#e9d4b3" />
        <animate attributeName="y1" values="0%;100%;0%" dur="6s" repeatCount="indefinite" />
      </linearGradient>
    
    <!-- Soft Light Filter -->
