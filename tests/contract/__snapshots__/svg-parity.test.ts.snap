        animation: plasmaEnergy 6s infinite;
      ">
        Hello World
      </div>
      <style>
        @keyframes plasmaEnergy {
          0%, 100% { transform: scale(1); opacity: 1; }
          50% { transform: scale(1.05); opacity: 0.9; }
        }
      </style>
    </foreignObject>
  
    </svg>"
`;

