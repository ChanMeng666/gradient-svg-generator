        <stop offset="0%" style="stop-color:#ff00ff;stop-opacity:1">
          <animate attributeName="stop-color" values="#ff00ff;#ff0080;#8000ff;#ff00ff" dur="6s" repeatCount="indefinite"/>
        </stop>
        <stop offset="50%" style="stop-color:#ff0080;stop-opacity:0.8">
          <animate attributeName="stop-color" values="#ff0080;#8000ff;#ff4080;#ff0080" dur="6s" repeatCount="indefinite"/>
        </stop>
        <stop offset="100%" style="stop-color:#8000ff;stop-opacity:0.4">
          <animate attributeName="stop-color" values="#8000ff;#ff4080;#ff00ff;#8000ff" dur="6s" repeatCount="indefinite"/>
        </stop>
        <animate attributeName="cx" values="30%;70%;30%" dur="6s" repeatCount="indefinite"/>
        <animate attributeName="cy" values="30%;70%;30%" dur="9s" repeatCount="indefinite"/>
      </radialGradient>
      <filter id="plasmaGlow">
        <feGaussianBlur stdDeviation="8" result="coloredBlur"/>
